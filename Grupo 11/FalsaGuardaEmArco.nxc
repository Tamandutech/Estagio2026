/* Ordem de montagem:

Motor da Direita na porta A
Motor da Rampa B
Motor da Esquerda na porta C
Sensor Esquerdo na porta 1
Sensor Direito  na porta 3

*/

//==============================================================================
//==============================================================================
//==============================================================================

// 1. DEFINIï¿½ï¿½O DE PORTAS E CONSTANTES (Mapeamento do Hardware)
#define motorDireita OUT_A    // Motor Direito --> entrada A
#define motorRampa OUT_B      // Possï¿½vel motor de Rampa --> entrada B
#define motorEsquerda OUT_C   // Motor Esquerdo --> entrada C
#define sensorE SensorUS(IN_1)// Sensor  --> entrada 1
#define sensorD SensorUS(IN_3)// Sensor  --> entrada 3


//__________MEXER PARA REGULAR A DISTANCIA DE BUSCA____________________________________
#define distancia_busca 35      // Limiar para o robï¿½ comeï¿½ar a andar para frente, em centï¿½metros

//==============================================================================
//=========================CORPO DO Cï¿½DIGO======================================
//==============================================================================

// 2. FUNï¿½ï¿½O DA RAMPA (Executada apenas uma vez no inï¿½cio)
void abaixarRampa() {
    OnFwd(motorRampa, 60);      // Liga o motor da rampa para frente com 60% de forï¿½a
    Wait(350);                  // Mantï¿½m o motor girando por 350 milissegundos para descer a rampa
    Off(motorRampa);            // Desliga o motor para a rampa ficar travada no chï¿½o
}
void movimentoInicial() {
    // Dï¿½ marcha rï¿½ por 800 milissegundos
    OnRev(motorDireita, 80);    // Motor direito para trï¿½s com 80% de forï¿½a
    OnRev(motorEsquerda, 80);   // Motor esquerdo para trï¿½s com 80% de forï¿½a
    Wait(800);                  // Mantï¿½m a marcha rï¿½ por 0.8 segundos

    // Freia bruscamente os motores para estabilizar a rampa no chï¿½o
    Off(motorDireita);
    Off(motorEsquerda);
    Wait(100);                  // Espera 100ms parado antes de abrir o radar
}



// 3. FUNï¿½ï¿½O PRINCIPAL (Onde o robï¿½ toma as decisï¿½es)
task main() {
    // Inicializa as portas digitais dos sensores ultrassï¿½nicos como "Lowspeed" (obrigatï¿½rio para I2C)
    SetSensorLowspeed(IN_1);    // Ativa o sensor esquerdo
    SetSensorLowspeed(IN_3);    // Ativa o sensor direito

    // Tempo de seguranï¿½a oficial exigido pelas regras da competiï¿½ï¿½o (5 segundos)
    Wait(5000);                 // Aguarda 5000 milissegundos parado na arena

    // Aciona a rampa assim que o round comeï¿½a para liberar o robï¿½ do gabarito
    abaixarRampa();

    // LOOP INFINITO: O robï¿½ executarï¿½ este bloco de decisï¿½es para sempre
    while(true) {

        // CENï¿½RIO A: Os dois sensores detectaram o adversï¿½rio na frente!
        if (sensorE < distancia_busca && sensorD < distancia_busca) {
            // Se o robï¿½ for para trï¿½s em vez de ir para frente, mude OnFwd para OnRev
            OnFwd(motorDireita, 100);   // Forï¿½a total no motor direito
            OnFwd(motorEsquerda, 100);  // Forï¿½a total no motor esquerdo (Ataque frontal!)
        }

        // CENï¿½RIO B: Apenas o sensor da ESQUERDA viu o inimigo
        else if (sensorE < distancia_busca && sensorD > distancia_busca) {
            OnRev(motorEsquerda, 60);   // Gira o motor esquerdo para trï¿½s
            OnFwd(motorDireita, 60);    // Gira o motor direito para frente (Gira rï¿½pido para a Esquerda)
            Wait(40);                   // Pequeno intervalo de tempo para estabilizar o giro
        }

        // CENï¿½RIO C: Apenas o sensor da DIREITA viu o inimigo
        else if (sensorE > distancia_busca && sensorD < distancia_busca) {
            OnFwd(motorEsquerda, 60);   // Gira o motor esquerdo para frente
            OnRev(motorDireita, 60);    // Gira o motor direito para trï¿½s (Gira rï¿½pido para a Direita)
            Wait(40);                   // Pequeno intervalo de tempo para estabilizar o giro
        }

        // CENï¿½RIO D: Ninguï¿½m estï¿½ ï¿½ vista (Estratï¿½gia de Busca)
        else {
            // Varredura em arco largo (nunca fica parado no mesmo lugar)
            OnFwd(motorDireita, 70);
            OnFwd(motorEsquerda, 20);
        }
    }
}
